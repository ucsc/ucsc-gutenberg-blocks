{
  "name": "ucsc-gutenberg-blocks",
  "version": "1.1.37",
  "description": "Adds custom blocks to UCSC WordPress websites",
  "main": "test.js",
  "scripts": {
    "build": "wp-scripts build",
    "start": "wp-scripts start",
    "test": "wp-scripts test-unit-js",
    "plugin-zip": "wp-scripts plugin-zip",
		"release": "commit-and-tag-version",
		"dryrun": "commit-and-tag-version --dry-run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ucsc/ucsc-gutenberg-blocks.git"
  },
  "keywords": [
    "WordPress",
    "plugin"
  ],
  "files": [
    "!package.json",
    "src",
    "classes",
    "templates",
    "index.php",
    "build"
  ],
  "author": "UC Santa Cruz",
  "license": "ISC",
  "devDependencies": {
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^12.1.5",
    "@wordpress/scripts": "^22.3.0",
		"commit-and-tag-version": "^12.7.3"
	},
	"commit-and-tag-version": {
		"bumpFiles": [
			{
				"filename": "package-lock.json",
				"type": "json"
			},
			{
				"filename": "package.json",
				"type": "json"
			},
			{
				"filename": "index.php",
				"updater": "wp-plugin-version-updater.js"
			}
		]
	}
}
